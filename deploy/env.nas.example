CRM_CLUSTER_ID=crm-prod
CRM_NODE_ID=nas-1
CRM_NODE_NAME=群晖NAS
CRM_HTTP_PORT=5001
CRM_CONTAINER_NAME=crm-barcode-query
CRM_POSTGRES_CONTAINER_NAME=crm-postgres
CRM_IMAGE=ghcr.io/lovegongqi/crm_barcode_query_cluster:latest
CRM_APP_DATA_VOLUME=crm_barcode_query_app_data
CRM_BROWSER_SESSION_VOLUME=crm_barcode_query_browser_session
CRM_POSTGRES_VOLUME=crm_barcode_query_postgres_data

CRM_QUERY_WORKERS=4
CRM_TRANSFER_WORKERS=2
CRM_REPORT_IDLE_SECONDS=3600

POSTGRES_DB=crm_barcode
POSTGRES_USER=crm
POSTGRES_PASSWORD=请改成强密码
POSTGRES_PUBLIC_PORT=15432

# 第二阶段数据迁移会使用这些 R2 配置；第一阶段先预留。
R2_BUCKET=crm-barcode-query
R2_ENDPOINT_URL=https://你的账号ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=填写R2访问Key
R2_SECRET_ACCESS_KEY=填写R2访问Secret
