CRM_CLUSTER_ID=crm-prod
CRM_NODE_ID=worker-1
CRM_NODE_NAME=云服务器1
CRM_PUBLIC_URL=http://hk.mlmll.cn:5012
CRM_HTTP_PORT=5001
CRM_CONTAINER_NAME=crm-barcode-query-worker-1
CRM_IMAGE=ghcr.io/lovegongqi/crm_barcode_query_cluster:latest
CRM_APP_DATA_VOLUME=crm_barcode_query_worker_1_app_data
CRM_BROWSER_SESSION_VOLUME=crm_barcode_query_worker_1_browser_session

CRM_QUERY_WORKERS=5
CRM_TRANSFER_WORKERS=2
CRM_REPORT_IDLE_SECONDS=3600
CRM_CLUSTER_ADMIN_TOKEN=请改成所有服务器一致的随机密钥
CRM_CLUSTER_NODES=[{"id":"nas-1","name":"群晖NAS","role":"nas","url":"http://mlmll.cn:5011"},{"id":"hk-1","name":"核云香港","role":"worker","url":"http://hk.mlmll.cn:5012"},{"id":"us-1","name":"核云美国","role":"worker","url":"http://us.mlmll.cn:5013"},{"id":"sg-1","name":"核云新加坡","role":"worker","url":"http://sg.mlmll.cn:5014"}]

# 指向群晖 PostgreSQL，只使用域名；群晖转发 15432/TCP 到容器 PostgreSQL。
DATABASE_URL=postgresql://crm:请改成强密码@mlmll.cn:15432/crm_barcode

R2_BUCKET=crm-barcode-query
R2_ENDPOINT_URL=https://你的账号ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=填写R2访问Key
R2_SECRET_ACCESS_KEY=填写R2访问Secret
