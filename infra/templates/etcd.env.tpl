ETCD_NAME=__NODE_ID__
ETCD_DATA_DIR=/etcd-data
ETCD_LISTEN_CLIENT_URLS=https://0.0.0.0:2379
ETCD_ADVERTISE_CLIENT_URLS=https://__NODE_HOST__:2379
ETCD_LISTEN_PEER_URLS=https://0.0.0.0:2380
ETCD_INITIAL_ADVERTISE_PEER_URLS=https://__NODE_HOST__:2380
ETCD_INITIAL_CLUSTER=hk=https://hk.mlmll.cn:2380,sg=https://sg.mlmll.cn:2380,us=https://us.mlmll.cn:2380
ETCD_INITIAL_CLUSTER_STATE=new
ETCD_INITIAL_CLUSTER_TOKEN=crm-barcode-etcd-v1
ETCD_CERT_FILE=/run/secrets/etcd-server.crt
ETCD_KEY_FILE=/run/secrets/etcd-server.key
ETCD_TRUSTED_CA_FILE=/run/secrets/ca.crt
ETCD_CLIENT_CERT_AUTH=true
ETCD_PEER_CERT_FILE=/run/secrets/etcd-peer.crt
ETCD_PEER_KEY_FILE=/run/secrets/etcd-peer.key
ETCD_PEER_TRUSTED_CA_FILE=/run/secrets/ca.crt
ETCD_PEER_CLIENT_CERT_AUTH=true
ETCD_AUTO_TLS=false
ETCD_PEER_AUTO_TLS=false
